# D-drive local development profile.
# Copy to .env only inside D:\Codex\esignature\src\open-signature when running locally.

# Frontend
PUBLIC_URL=http://127.0.0.1:3000
GENERATE_SOURCEMAP=false
REACT_APP_SERVERURL=http://127.0.0.1:8080/app
REACT_APP_APPID=sealhouse
REACT_APP_DOCS_URL=
REACT_APP_GITHUB_URL=
REACT_APP_LINKEDIN_URL=
REACT_APP_X_URL=
REACT_APP_DISCORD_URL=
REACT_APP_RELEASE_URL=
REACT_APP_MAIL_LOGO_URL=

# Backend / Parse Server
APP_NAME=Sealhouse
appName=Sealhouse
APP_ID=sealhouse
MASTER_KEY=change-this-12-plus-character-local-key
MONGODB_URI=mongodb://127.0.0.1:27017/SealhouseDB
PARSE_MOUNT=/app
SERVER_URL=http://127.0.0.1:8080/app

# Keep document storage local. Run the server from apps\OpenSignServer so
# the Parse files adapter writes under this D-drive repository.
USE_LOCAL=true

# Email is disabled by default for first local boot. Add a local SMTP catcher
# or real SMTP settings before testing invitation/OTP flows.
SMTP_ENABLE=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER_EMAIL=
SMTP_USERNAME=
SMTP_PASS=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SENDER=

# Optional operational contacts used in generated emails and support text.
SUPPORT_EMAIL=
ABUSE_EMAIL=
MAIL_LOGO_URL=

# Optional hosted integrations. These are disabled unless set.
SSO_API_URL=
NEWSLETTER_API_URL=

# Development signing certificate. Generate a throwaway local PFX and paste
# the base64 here before validating final PDF signature behavior.
PFX_BASE64=
PASS_PHRASE=
